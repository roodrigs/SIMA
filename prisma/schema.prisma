generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Question {
  id            String   @id @default(cuid())
  category      String   // MATEMATICA_LOGICA, PORTUGUES, CIENCIAS_BIOLOGICAS, HISTORIA
  grade         Int      @default(12) // 12 represents 3º ano Ensino Médio
  text          String
  options       Json     // No PostgreSQL, usamos Json nativo
  correctAnswer Int      // Índice da resposta correta (0-3)
  description   String   @default("") // Adicionado para explicação da resposta
  createdAt     DateTime @default(now())
  answers       Answer[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Assessment {
  id              String   @id @default(cuid())
  operatorName    String
  intervieweeName String
  schoolName      String
  schoolClass     String   // Adicionado: Turma
  grade           Int      @default(12) // 12 represents 3º ano Ensino Médio
  zone            String   @default("NORTE") // NORTE, SUL, LESTE, OESTE
  schoolNetwork   String   @default("PUBLICA") // PARTICULAR, PUBLICA
  date            DateTime @default(now())
  answers         Answer[]
}

model Answer {
  id           String     @id @default(cuid())
  assessmentId String
  questionId   String
  selectedIdx  Int
  isCorrect    Boolean
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  question     Question   @relation(fields: [questionId], references: [id])
}