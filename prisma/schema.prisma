generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
}

model Question {
  id            String   @id @default(cuid())
  category      String   // MATEMATICA, CIENCIAS, GEOGRAFIA
  grade         Int      @default(5) // 5, 6, 7, 8, 9
  text          String
  options       Json     // No PostgreSQL, usamos Json nativo
  correctAnswer Int      // Índice da resposta correta (0-3)
  createdAt     DateTime @default(now())
  answers       Answer[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Assessment {
  id              String   @id @default(cuid())
  operatorName    String
  intervieweeName String
  schoolName      String
  schoolClass     String   // Adicionado: Turma
  grade           Int      @default(5)
  zone            String   @default("NORTE") // NORTE, SUL, LESTE, OESTE
  region          String   @default("URBANA") // URBANA, RURAL
  date            DateTime @default(now())
  answers         Answer[]
}

model Answer {
  id           String     @id @default(cuid())
  assessmentId String
  questionId   String
  selectedIdx  Int
  isCorrect    Boolean
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  question     Question   @relation(fields: [questionId], references: [id])
}